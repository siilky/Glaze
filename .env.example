# === Cloud Sync — OAuth Configuration ===
# Fill these in with your own OAuth app credentials.
# See Roadmap.md "Sync Setup Guide" for step-by-step instructions.

# Dropbox (https://www.dropbox.com/developers/apps)
VITE_DROPBOX_APP_KEY=
VITE_DROPBOX_REDIRECT_NATIVE=com.hydall.glaze://oauth/dropbox
VITE_DROPBOX_REDIRECT_WEB=

# Google Drive (https://console.cloud.google.com → Enable Drive API → Credentials)
VITE_GDRIVE_CLIENT_ID=
VITE_GDRIVE_CLIENT_SECRET=
VITE_GDRIVE_REDIRECT_NATIVE=com.hydall.glaze://oauth/gdrive
VITE_GDRIVE_REDIRECT_WEB=
