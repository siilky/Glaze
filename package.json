{
  "name": "glaze",
  "private": true,
  "version": "0.4.1-alpha",
  "license": "AGPL-3.0-only",
  "author": "hydall <hydallatglaze@gmail.com>",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "sync-version": "node scripts/sync-version.js"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "@vitejs/plugin-legacy": "^7.2.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/ui": "^4.0.18",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "happy-dom": "^20.6.1",
    "sharp": "^0.34.5",
    "terser": "^5.44.1",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@anuradev/capacitor-background-mode": "^7.2.1",
    "@capacitor-community/safe-area": "^8.0.1",
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/browser": "^8.0.2",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/filesystem": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/local-notifications": "^8.0.0",
    "@capacitor/share": "^8.0.0",
    "@capacitor/toast": "^8.0.0",
    "@capawesome-team/capacitor-android-foreground-service": "^8.0.0",
    "@capawesome/capacitor-background-task": "^8.0.0",
    "jszip": "^3.10.1",
    "vue": "^3.5.26",
    "vue-i18n": "^11.2.8"
  },
  "build": {
    "appId": "com.hydall.glaze",
    "productName": "Glaze",
    "icon": "assets/logo.png",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true
    },
    "linux": {
      "target": [
        "deb",
        "pacman",
        "AppImage"
      ],
      "category": "Utility"
    }
  }
}
